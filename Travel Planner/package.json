{
  "name": "ai-travel-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/devWithFrontendSync.mjs",
    "dev:vite": "vite",
    "dev:server": "node --watch server/index.js",
    "server": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test",
    "build:india-data": "python3 ./scripts/buildIndiaTravelData.py",
    "sync:frontend": "node ./scripts/frontendBackupSync.mjs --full",
    "sync:frontend:watch": "node ./scripts/frontendBackupSync.mjs --watch",
    "verify:trip-pdf-ui": "node ./scripts/verifyTripPdfUi.mjs",
    "audit:full": "npm audit",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "d3-geo": "^3.1.1",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "firebase": "^11.5.0",
    "firebase-admin": "^13.7.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.483.0",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.2",
    "react-toastify": "^11.0.5",
    "tailwind-merge": "^3.0.2",
