# -----------------------------
# Frontend (Vite + Firebase Web)
# -----------------------------
# Leave blank to use same-origin requests in production.
VITE_API_BASE_URL=http://localhost:3001
VITE_DEV_API_PROXY=http://localhost:3001

# Firebase project settings (Firebase Console -> Project Settings -> General -> Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# -----------------------------
# Backend (Node API)
# -----------------------------
PORT=3001
NODE_ENV=development

# Firebase Admin SDK (recommended for secure server-side auth verification)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Hybrid relational store (PostgreSQL + PostGIS)
SQL_ENABLE=true
SQL_DATABASE_URL=postgresql://user:password@localhost:5432/ai_travel_planner
SQL_MAX_POOL_SIZE=10
SQL_IDLE_TIMEOUT_MS=30000
SQL_CONNECT_TIMEOUT_MS=10000
SQL_SSL_MODE=disable
SQL_SSL_ALLOW_SELF_SIGNED=false
SQL_STRICT_MODE=false

# Gemini (server-only)
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=20000
GEMINI_MAX_RETRIES=1

# Destination recommendations (server-only)
GOOGLE_PLACES_API_KEY=
RECOMMENDATIONS_PROVIDER_TIMEOUT_MS=8000
RECOMMENDATIONS_CACHE_TTL_MS=300000
RECOMMENDATIONS_MOCK_CACHE_TTL_MS=30000
DESTINATION_FRESHNESS_TTL_MS=86400000

# Security / API controls
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRIP_GENERATION_RATE_LIMIT_WINDOW_MS=60000
TRIP_GENERATION_RATE_LIMIT_MAX=6
RECOMMENDATIONS_RATE_LIMIT_WINDOW_MS=60000
RECOMMENDATIONS_RATE_LIMIT_MAX=30
ROUTE_OPTIMIZATION_RATE_LIMIT_WINDOW_MS=60000
ROUTE_OPTIMIZATION_RATE_LIMIT_MAX=30
OUTBOUND_ALLOWED_HOSTS=maps.googleapis.com,generativelanguage.googleapis.com,api.upstash.com

# Route optimization and algorithm controls
ROUTE_CANDIDATE_LIMIT=24
PYTHON_BIN=python3
PYTHON_ROUTE_OPTIMIZER_PATH=
PYTHON_OPTIMIZER_TIMEOUT_MS=10000
PLANNING_USE_GEMINI_NARRATIVE=true
TRIP_PLANNING_FALLBACK_ENABLED=true
TRIP_MEMORY_FALLBACK_ENABLED=true

# Optional L2 distributed cache (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_SECRET_KEY=
