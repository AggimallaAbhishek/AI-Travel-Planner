# -----------------------------
# Frontend (Vite + Firebase Web)
# -----------------------------
# Leave blank to use same-origin requests in production and on Vercel.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY=http://localhost:3001
VITE_API_REQUEST_TIMEOUT_MS=30000
# Browser-restricted Google Maps JavaScript API key for the day-synced itinerary map.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Firebase project settings (Firebase Console -> Project Settings -> General -> Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# -----------------------------
# Backend (Node API)
# -----------------------------
PORT=3001
NODE_ENV=development

# Firebase Admin SDK (recommended for secure server-side auth verification)
# Optional once backend auth moves to JWT/JWKS verification without Firebase Admin.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_JSON=

# Gemini (server-only)
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=20000
GEMINI_MAX_RETRIES=1

# Planner-Critic-Repair feature flag (server-only)
FEATURE_PLANNER_CRITIC_REPAIR=false
FUSION_TIMEOUT_MS=5000
MIN_FUSION_CONFIDENCE=0.55

# Destination recommendations (server-only)
# Optional: if omitted, the app tries OpenStreetMap live data before falling back
# to curated sample hotels/restaurants.
GOOGLE_PLACES_API_KEY=
# Optional dedicated Maps / Routes key. If omitted, the app reuses GOOGLE_PLACES_API_KEY.
GOOGLE_MAPS_API_KEY=
DESTINATION_RECOMMENDATION_LIMIT=6
DESTINATION_RECOMMENDATION_CACHE_TTL_MS=900000
DESTINATION_RECOMMENDATION_STALE_TTL_MS=300000
DESTINATION_RECOMMENDATION_MOCK_CACHE_TTL_MS=60000
DESTINATION_RECOMMENDATION_TIMEOUT_MS=12000
GOOGLE_PLACE_PHOTO_TIMEOUT_MS=4000
DESTINATION_RECOMMENDATION_RADIUS_METERS=3000
OSM_USER_AGENT=AI-Travel-Planner/1.0 (destination recommendations)
# Optional overrides for OpenStreetMap endpoints.
NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Route optimization
ROUTE_OPTIMIZER_MAX_STOPS_PER_DAY=8
ROUTE_OPTIMIZER_FALLBACK_SPEED_MPS=10
ROUTE_REQUEST_TIMEOUT_MS=12000
TRIP_MAP_GEOCODE_TIMEOUT_MS=12000
EXTERNAL_READ_RETRIES=0
ENRICH_TRIP_MAP_ON_CREATE=false
PYTHON_ROUTE_OPTIMIZER_ENABLED=false
PYTHON_EXECUTABLE=python3

# Hybrid cache layer (optional Redis). Falls back to in-memory cache if unset.
REDIS_URL=
CACHE_DEFAULT_TTL_MS=900000
CACHE_DEFAULT_STALE_TTL_MS=300000

# Security / API controls
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRIP_GENERATION_RATE_LIMIT_WINDOW_MS=60000
TRIP_GENERATION_RATE_LIMIT_MAX=6
REPLAN_RATE_LIMIT_WINDOW_MS=60000
REPLAN_RATE_LIMIT_MAX=6
ADAPTIVE_RATE_LIMIT_WINDOW_MS=60000
ADAPTIVE_RATE_LIMIT_MAX=8
ADAPTIVE_RATE_LIMIT_MAX_PENALTY=4

GOOGLE_CLIENT_ID=
GOOGLE_SECRET_KEY=
